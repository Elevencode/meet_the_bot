# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google API Configuration
# IMPORTANT: Store service account JSON outside the repository for security
# Recommended path: ~/credentials/meet_the_bot/service-account.json
GOOGLE_SERVICE_ACCOUNT_PATH=/Users/your_username/credentials/meet_the_bot/service-account.json

# Backend Service Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Logging Configuration
LOG_LEVEL=INFO 